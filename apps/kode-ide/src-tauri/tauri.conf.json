{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "kode-ide",
  "version": "0.1.0",
  "identifier": "com.admin.kode-ide",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Kode IDE",
        "width": 1600,
        "height": 1024,
        "minWidth": 1280,
        "minHeight": 820
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
