{
  "expo": {
    "name": "Kontinue AI",
    "slug": "mobile-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/kontinue-icon.png",
    "scheme": "mobileapp",
    "userInterfaceStyle": "automatic",
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0B0A0C",
        "foregroundImage": "./assets/images/kontinue-icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/kontinue-icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0B0A0C",
          "image": "./assets/images/kontinue-icon.png",
          "imageWidth": 120,
          "dark": {
            "backgroundColor": "#0B0A0C",
            "image": "./assets/images/kontinue-icon.png",
            "imageWidth": 120
          }
        }
      ],
      "expo-secure-store",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
